EXIM_API_KEY=your_korea_exim_api_key

# Optional shared storage for Vercel / other PCs.
# Deploy google-apps-script/ops-shared-storage.gs as a Google Apps Script Web App,
# then paste the Web App URL and the same secret here and in Vercel Environment Variables.
OPS_SHARED_STORAGE_URL=https://script.google.com/macros/s/your_web_app_id/exec
OPS_SHARED_STORAGE_SECRET=change-this-secret
